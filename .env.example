# ─── El Niño Early Warning — Environment Variables ───────────────────────────
# Copy this file to .env.local for local dev, or set these in Railway.app dashboard.
# NEVER commit .env.local to git.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From Supabase Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key — pipeline only, NEVER in browser
SUPABASE_ANON_KEY=eyJ...     # anon key — dashboard read-only (NEXT_PUBLIC_ prefix)

# Supabase PostgreSQL (for dbt — use Session pooler connection string)
# Project Settings → Database → Connection string → Session mode
SUPABASE_DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres

# ─── Anthropic (Claude haiku for advisories) ──────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Semaphore.ph (SMS) ───────────────────────────────────────────────────────
# https://semaphore.co — account API key
SEMAPHORE_API_KEY=your-semaphore-api-key
SEMAPHORE_SENDER_NAME=ELNINO-PH   # max 11 chars

# ─── PAGASA PDF URL ──────────────────────────────────────────────────────────
# Update when PAGASA publishes a new bulletin URL
PAGASA_BULLETIN_URL=https://www.pagasa.dost.gov.ph/climate/climate-prediction/seasonal-forecast

# ─── Manual PAGASA override (optional) ───────────────────────────────────────
# JSON string: {"nueva ecija": {"seasonal_outlook": "Below Normal", "rainfall_anomaly_pct": -30.0}}
# Use when PDF parsing fails and the automated fallback data needs updating.
# PAGASA_MANUAL_OVERRIDE=

# ─── Vercel (dashboard rebuild trigger) ───────────────────────────────────────
# Vercel → Project → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# ─── Next.js dashboard (public — safe to expose to browser) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon key only

# ─── Pipeline config ─────────────────────────────────────────────────────────
PIPELINE_DIR=/app/pipeline     # Railway: /app/pipeline — local: absolute path
SMS_DRY_RUN=false              # Set to true to skip actual SMS sends
TEST_PHONE_NUMBER=+639495034475  # Used by: python send_sms.py --test
